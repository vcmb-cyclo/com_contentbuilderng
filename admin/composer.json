{
  "name": "xda-gil/com_contentbuilderng",
  "type": "joomla-component",
  "require": {
    "bgli100/securimage": "^4.0",
    "phpoffice/phpspreadsheet": "^5.6"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "post-install-cmd": [
      "@php scripts/prune-securimage-audio.php"
    ],
    "post-update-cmd": [
      "@php scripts/prune-securimage-audio.php"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.22"
  }
}
