{
    "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
    "name": "com_contentbuilderng",
    "version": "6.1.1",
    "description": "Assets pour le composant ContentBuilderng",
    "assets": [
        {
            "name": "com_contentbuilderng.admin-toolbar",
            "type": "style",
            "uri": "com_contentbuilderng/css/admin-toolbar.css"
        },
        {
            "name": "com_contentbuilderng.system",
            "type": "style",
            "uri": "com_contentbuilderng/css/system.css"
        },
        {
            "name": "com_contentbuilderng.form-edit",
            "type": "style",
            "uri": "com_contentbuilderng/css/form-edit.css"
        },
        {
            "name": "com_contentbuilderng.contentbuilderng",
            "type": "script",
            "uri": "com_contentbuilderng/js/contentbuilderng.js",
            "dependencies": [
                "core"
            ]
        },
        {
            "name": "com_contentbuilderng.admin-ui",
            "type": "script",
            "uri": "com_contentbuilderng/js/admin-ui.js",
            "dependencies": [
                "core"
            ],
            "attributes": {
                "defer": true
            }
        },
        {
            "name": "com_contentbuilderng.contentbuilderng",
            "type": "script",
            "uri": "com_contentbuilderng/js/contentbuilderng.js",
            "dependencies": [
                "core"
            ]
        },
        {
            "name": "com_contentbuilderng.jscolor",
            "type": "script",
            "uri": "com_contentbuilderng/js/jscolor/jscolor.js",
            "dependencies": [
                "core"
            ]
        },
        {
            "name": "com_contentbuilderng.coloris.css",
            "type": "style",
            "uri": "https://cdn.jsdelivr.net/npm/@melloware/coloris@0.25.0/dist/coloris.min.css"
        },
        {
            "name": "com_contentbuilderng.coloris.js",
            "type": "script",
            "uri": "https://cdn.jsdelivr.net/npm/@melloware/coloris@0.25.0/dist/umd/coloris.min.js",
            "dependencies": [
                "core"
            ],
            "attributes": {
                "defer": true
            }
        }
    ]
}
