<?xml version="1.0" encoding="utf-8" ?>
<metadata>
    <!-- Joomla! 1.6 compatibility -->
    <layout title="COM_CONTENTBUILDERNG_MENU_ITEM_CREATE">
        <message>COM_CONTENTBUILDERNG_CREATE_MESSAGE</message>
        <config>
            <fields name="params" addfieldprefix="CB\Component\Contentbuilderng\Site\Field">
                <fieldset name="settings" group="settings" label="COM_CONTENTBUILDERNG_MENU_ITEM_LIST">
                    <field required="true" type="forms" label="COM_CONTENTBUILDERNG_SELECT_VIEW" description="COM_CONTENTBUILDERNG_SELECT_VIEW_DESC" name="form_id" default="0"/>
                    <field type="categories" label="COM_CONTENTBUILDERNG_SELECT_CATEGORY" description="COM_CONTENTBUILDERNG_SELECT_CATEGORY_DESC" name="cb_category_id" default="0" />
                    <field name="show_back_button" type="radio" default="0" label="COM_CONTENTBUILDERNG_SHOW_BACK_BUTTON" description="COM_CONTENTBUILDERNG_SHOW_BACK_BUTTON_DESC">
                        <option value="0">COM_CONTENTBUILDERNG_NO</option>
                        <option value="1">COM_CONTENTBUILDERNG_YES</option>
                    </field>
                    <field name="cb_show_author" type="radio" default="1" description="COM_CONTENTBUILDERNG_SHOW_AUTHOR_DESC" label="COM_CONTENTBUILDERNG_SHOW_AUTHOR">
                        <option value="0">No</option>
                        <option value="1">Yes</option>
                    </field>
                    <field name="cb_show_top_bar" type="radio" default="1" description="COM_CONTENTBUILDERNG_SHOW_TOP_BAR_DESC" label="COM_CONTENTBUILDERNG_SHOW_TOP_BAR">
                        <option value="0">No</option>
                        <option value="1">Yes</option>
                    </field>
                    <field name="cb_show_bottom_bar" type="radio" default="1" description="COM_CONTENTBUILDERNG_SHOW_BOTTOM_BAR_DESC" label="COM_CONTENTBUILDERNG_SHOW_BOTTOM_BAR">
                        <option value="0">No</option>
                        <option value="1">Yes</option>
                    </field>
                    <field name="cb_prefix_in_title" type="radio" default="1" label="COM_CONTENTBUILDERNG_PREFIX_IN_TITLE" description="">
                        <option value="0">COM_CONTENTBUILDERNG_NO</option>
                        <option value="1">COM_CONTENTBUILDERNG_YES</option>
                    </field>
                    <field type="hidden" name="cb_controller" default="edit" />
                </fieldset>
            </fields>
        </config>
    </layout>
</metadata>
