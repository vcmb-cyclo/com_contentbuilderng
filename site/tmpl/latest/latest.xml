                        <option value="-1">JOPTION_USE_DEFAULT</option>
                        <option value="0">COM_CONTENTBUILDERNG_NO</option>
                        <option value="1">COM_CONTENTBUILDERNG_YES</option>
                    </field>
                    <field name="cb_show_author" type="radio" class="btn-group btn-group-yesno" default="-1" description="COM_CONTENTBUILDERNG_SHOW_AUTHOR_DESC" label="COM_CONTENTBUILDERNG_SHOW_AUTHOR">
