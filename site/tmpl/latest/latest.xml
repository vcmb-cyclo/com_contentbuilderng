<?xml version="1.0" encoding="utf-8" ?>
<metadata>
    <!-- Joomla! 1.6 compatibility -->
    <layout title="COM_CONTENTBUILDERNG_MENU_ITEM_LATEST">
        <message>COM_CONTENTBUILDERNG_SELECT_LATEST_MESSAGE</message>
        <config>
            <fields name="params" addfieldprefix="CB\Component\Contentbuilderng\Site\Field">
                <fieldset name="settings" group="settings" label="COM_CONTENTBUILDERNG_MENU_ITEM_LIST">
                    <field type="forms" label="COM_CONTENTBUILDERNG_SELECT_VIEW" name="form_id" default="0"/>
                    <field type="cbmenureset" label="" description="" name="cb_menu_reset" />
                    <field type="note" label="COM_CONTENTBUILDERNG_MENU_OPTIONS_DETAILS" class="cb-menu-section-heading" />
