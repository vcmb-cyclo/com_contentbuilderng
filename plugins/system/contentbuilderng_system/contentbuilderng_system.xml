<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" version="6.0" method="upgrade">
	<name>ContentBuilder NG System</name>
	<creationDate>2026-07-20</creationDate>
	<author>XDA+GIL</author>
    <license>GNU/GPL v2 or later https://www.gnu.org/licenses/old-licenses/gpl-2.0.html</license>
	<copyright>This Joomla! component is released under the GNU/GPL license</copyright>
	<authorEmail>noreply@vcmb.fr</authorEmail>
	<authorUrl>breezingforms-ng.vcmb.fr</authorUrl>
	<version>6.1.7-RC88</version>

	<description>PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_XML_DESCRIPTION</description>
    <namespace path="src">CB\Plugin\System\ContentbuilderngSystem</namespace>
            <files>
        <filename plugin="contentbuilderng_system">services/provider.php</filename>
        <folder>src</folder>
        <folder>language</folder>
    </files>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="limit_per_turn" type="text" default="50" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_LIMIT_PER_TURN_LABEL"/>
                <field name="disable_new_articles" type="radio" default="1" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_DISABLE_NEW_ARTICLES_LABEL">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="nocache" type="radio" default="1" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_NOCACHE_LABEL" description="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_NOCACHE_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="is_auto_groups" type="radio" default="0" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_IS_AUTO_GROUPS_LABEL" description="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_IS_AUTO_GROUPS_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="auto_groups" multiple="true" type="usergroup" default="" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_AUTO_GROUPS_LABEL" description="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_AUTO_GROUPS_DESC" />
                <field name="auto_groups_limit_views" type="text" default="" label="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_AUTO_GROUPS_LIMIT_VIEWS_LABEL" description="PLG_SYSTEM_CONTENTBUILDERNG_SYSTEM_FIELD_AUTO_GROUPS_LIMIT_VIEWS_DESC"/>
            </fieldset>
        </fields>
    </config>
</extension>
