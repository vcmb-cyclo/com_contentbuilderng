includes:
    - phpstan-baseline.neon

parameters:
    level: 1
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - admin/src
        - admin/layouts
        - site/src
        - site/layouts
        - plugins
        - script.php
    excludePaths:
        - admin/vendor
    # Joomla core classes are not installed as a composer dependency.
    # Point "joomla-stubs" at a Joomla 6 root (symlink locally, checkout in CI).
    scanDirectories:
        - joomla-stubs/libraries
    treatPhpDocTypesAsCertain: false
    # Include paths are built from JPATH_* constants and only resolve in a
    # deployed Joomla install, not in the repository layout.
    ignoreErrors:
        - '#^Path in (require|include)(_once)?\(\) ".*" is not a file or it does not exist\.$#'
    # Tolerate baseline entries that no longer match: the analysed Joomla core
    # (local install vs CI docker image) may differ slightly in version.
    reportUnmatchedIgnoredErrors: false
